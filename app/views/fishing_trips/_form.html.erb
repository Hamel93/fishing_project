<%= form_with model: fishing_trip do |f| %>
  <div>
    <%= f.label :lake_id %>
    <%= f.number_field :lake_id %>
  </div>

  <div>
    <%= f.label :custom_location_name %>
    <%= f.text_field :custom_location_name %>
  </div>

  <div>
    <%= f.label :latitude %>
    <%= f.number_field :latitude, step: :any %>
  </div>

  <div>
    <%= f.label :longitude %>
    <%= f.number_field :longitude, step: :any %>
  </div>

  <div>
    <%= f.label :fish_species %>
    <%= f.text_field :fish_species %>
  </div>

  <div>
    <%= f.label :lure_used %>
    <%= f.text_field :lure_used %>
  </div>

  <div>
    <%= f.label :date_fished %>
    <%= f.date_field :date_fished %>
  </div>

  <div>
    <%= f.label :notes %>
    <%= f.text_area :notes %>
  </div>

  <div>
    <%= f.submit %>
  </div>
<% end %>
