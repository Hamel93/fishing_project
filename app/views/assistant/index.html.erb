<div class="test-wrap">
  <h1>Fishing AI Test</h1>

  <div class="messages">
    <% @messages.each do |message| %>
      <div class="msg <%= message[:role] %>">
        <strong><%= message[:role].capitalize %>:</strong>
        <%= simple_format(message[:content]) %>
      </div>
    <% end %>
  </div>

  <form action="/assistant" method="get" class="ai-form">
    <input
      type="text"
      name="question"
      class="ai-input"
      placeholder="Écris ici ta question..."
      autocomplete="off"
    >
    <button type="submit" class="ai-button">Envoyer</button>
  </form>
</div>
